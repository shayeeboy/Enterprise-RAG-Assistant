# Copy to .env and fill in. Everything here has a free/local default except
# DATABASE_URL. Never commit the real .env (it's gitignored).

# --- Required: Neon Postgres connection string (the loaded vector DB) ---
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# --- LLM (free/local by default via Ollama) ---
# Install Ollama (https://ollama.com), then: `ollama pull llama3.2:3b`
# (small/fast default; for higher quality use `ollama pull llama3.1:8b` and set LLM_MODEL=llama3.1:8b)
LLM_PROVIDER=ollama
LLM_MODEL=llama3.2:3b
OLLAMA_HOST=http://127.0.0.1:11434
LLM_TEMPERATURE=0.2

# Faster, higher-quality option — Groq's FREE tier (OpenAI-compatible, no billing).
# Get a key at https://console.groq.com. This is the Phase 3 hosting choice: it
# cuts the LLM stage from ~200s (local CPU) to ~1s. To use it, comment the three
# Ollama lines above and uncomment these:
# LLM_PROVIDER=openai-compatible
# LLM_BASE_URL=https://api.groq.com/openai/v1
# LLM_API_KEY=gsk_...
# LLM_MODEL=llama-3.3-70b-versatile        # or llama-3.1-8b-instant for lower latency

# Any other OpenAI-compatible endpoint works the same way (may incur cost):
# LLM_BASE_URL=https://your-endpoint/v1  · LLM_API_KEY=...  · LLM_MODEL=...

# --- Retrieval / ranking (sensible free defaults) ---
EMBED_MODEL=mixedbread-ai/mxbai-embed-large-v1
RERANK_MODEL=Xenova/bge-reranker-base
ENABLE_QUERY_REWRITE=true
HYBRID_CANDIDATES=20
RERANK_INPUT=10
TOP_K=6
VECTOR_THRESHOLD=0.30
RERANK_THRESHOLD=0.05

# --- Server / deployment (Phase 3) ---
PORT=8080
# Comma-separated browser origins allowed to call the API (leave empty for local
# dev = allow all). In production set to your front-end origin, e.g.:
# ALLOWED_ORIGINS=https://shayeeboy.github.io
ALLOWED_ORIGINS=
# Per-IP rate limit on /ask
RATE_LIMIT_MAX=30
RATE_LIMIT_WINDOW_MS=60000
# Optional shared access code to gate /ask (empty = no gate). If set, the front
# end must send it (window.RAG_ACCESS_CODE) or requests get 401.
ACCESS_CODE=
