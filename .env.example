# Copy to .env and fill in. Everything here has a free/local default except
# DATABASE_URL. Never commit the real .env (it's gitignored).

# --- Required: Neon Postgres connection string (the loaded vector DB) ---
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# --- LLM (free/local by default via Ollama) ---
# Install Ollama (https://ollama.com), then: `ollama pull llama3.2:3b`
# (small/fast default; for higher quality use `ollama pull llama3.1:8b` and set LLM_MODEL=llama3.1:8b)
LLM_PROVIDER=ollama
LLM_MODEL=llama3.2:3b
OLLAMA_HOST=http://127.0.0.1:11434
LLM_TEMPERATURE=0.2

# To use any OpenAI-compatible endpoint instead (optional, may incur cost):
# LLM_PROVIDER=openai-compatible
# LLM_BASE_URL=https://your-endpoint/v1
# LLM_API_KEY=sk-...
# LLM_MODEL=your-model

# --- Retrieval / ranking (sensible free defaults) ---
EMBED_MODEL=mixedbread-ai/mxbai-embed-large-v1
RERANK_MODEL=Xenova/bge-reranker-base
ENABLE_QUERY_REWRITE=true
HYBRID_CANDIDATES=20
RERANK_INPUT=20
TOP_K=6
VECTOR_THRESHOLD=0.30
RERANK_THRESHOLD=0.05

# --- Server ---
PORT=8080
