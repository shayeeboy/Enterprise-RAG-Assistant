{
  "name": "ai-native-piano-rag",
  "version": "1.0.0",
  "description": "AI-Native Piano Learning RAG Assistant — ingestion pipeline, query-time assistant, and free off-localhost hosting with observability",
  "main": "scripts/run_all.js",
  "scripts": {
    "parse": "node scripts/01_parse.js",
    "chunk": "node scripts/02_chunk.js",
    "metadata": "node scripts/03_metadata.js",
    "embed": "node scripts/04_embed.js",
    "index": "node scripts/05_index.js",
    "offline": "npm run parse && npm run chunk && npm run metadata",
    "build": "npm run offline && npm run embed && npm run index",
    "query": "node scripts/06_query.js",
    "serve": "node server.js",
    "check": "node scripts/check.js",
    "smoke": "node scripts/smoke.js",
    "eval": "node scripts/eval.js",
    "eval:judge": "node scripts/eval-judge.js",
    "logs": "node scripts/logs.js",
    "stats": "node scripts/stats-readme.js"
  },
  "dependencies": {
    "@xenova/transformers": "^2.17.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "pg": "^8.11.5"
  },
  "engines": {
    "node": ">=18"
  }
}
